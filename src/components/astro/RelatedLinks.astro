---
/** Internal-linking block driven by site-architecture.json rules. */
const { lang = "en", links = [], currentPath = "" } = Astro.props;
const heading = lang === "es" ? "Sigue explorando" : "Keep exploring";
const visible = links.filter((link) => link.path !== currentPath);
---

{
  visible.length > 0 && (
    <nav class="my-12" aria-label={heading}>
      <h2 class="font-sans text-xl font-bold text-navy-700 mb-4">{heading}</h2>
      <ul class="grid gap-3 sm:grid-cols-2">
        {visible.map((link) => (
          <li>
            <a
              href={`${link.path}/`}
              class="block rounded-xl border border-border bg-surface p-4 shadow-card hover:shadow-card-hover transition-shadow text-navy-700 font-medium"
            >
              {link.label} <span aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}
