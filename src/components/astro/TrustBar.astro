---
import { BRAND } from "../../config/site.js";

const { lang = "en" } = Astro.props;
const signals = lang === "es" ? BRAND.trustSignals_es : BRAND.trustSignals_en;
---

<div class="bg-surfaceAlt rounded-xl px-4 py-3 my-6 overflow-x-auto">
  <ul class="flex gap-2 sm:justify-center whitespace-nowrap">
    {
      signals.map((signal) => (
        <li class="text-xs font-medium text-navy-500 bg-surface border border-border rounded-full px-3 py-1.5">
          {signal}
        </li>
      ))
    }
  </ul>
</div>
