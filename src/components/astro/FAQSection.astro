---
/** Visible FAQ section + FAQPage JSON-LD, built from fanout keywords. */
const { lang = "en", faq = [] } = Astro.props;
const heading = lang === "es" ? "Preguntas frecuentes" : "Frequently asked questions";

const stripTags = (s) => s.replace(/<[^>]*>/g, "");
const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.map((item) => ({
    "@type": "Question",
    name: stripTags(item.q),
    acceptedAnswer: { "@type": "Answer", text: stripTags(item.a) },
  })),
};
---

{
  faq.length > 0 && (
    <section class="my-12">
      <h2 class="font-sans text-2xl font-bold text-navy-700 mb-6">{heading}</h2>
      <div class="space-y-4">
        {faq.map((item) => (
          <details class="group rounded-xl border border-border bg-surface p-5 shadow-card open:shadow-card-hover">
            <summary class="cursor-pointer font-semibold text-navy-700 list-none flex justify-between items-center gap-3">
              <span>{item.q}</span>
              <span class="text-teal-500 group-open:rotate-45 transition-transform text-xl leading-none" aria-hidden="true">
                +
              </span>
            </summary>
            <p class="mt-3 text-text-secondary leading-relaxed" set:html={item.a} />
          </details>
        ))}
      </div>
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    </section>
  )
}
