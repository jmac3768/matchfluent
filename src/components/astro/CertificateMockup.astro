---
/** Landscape certificate card for career lesson tracks. */
const { title, subtitle, track } = Astro.props;
---

<div class="my-10 rounded-xl border-2 border-navy-700 bg-surface p-8 sm:p-10 shadow-card relative overflow-hidden">
  <div class="absolute top-0 left-0 right-0 h-1.5 bg-gold-500" aria-hidden="true"></div>
  <p class="text-xs uppercase tracking-widest text-text-muted mb-4">MatchFluent · {track}</p>
  <p class="font-display text-3xl sm:text-4xl font-bold text-navy-700 mb-2">{title}</p>
  <p class="text-text-secondary">{subtitle}</p>
  <div class="mt-6 flex items-center justify-between text-xs text-text-muted">
    <span class="font-mono">matchfluent.com</span>
    <span class="w-16 h-px bg-gold-500" aria-hidden="true"></span>
  </div>
</div>
