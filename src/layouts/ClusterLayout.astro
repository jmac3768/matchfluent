---
/**
 * Template for cluster pages and their fanout children — the full
 * conversion template: QuickAnswer, entity paragraph, question-H2
 * sections, mid-page intercept, static comparison table, condensed
 * quiz entry, FAQ (drives FAQPage schema), final CTA, related links.
 */
import BaseLayout from "./BaseLayout.astro";
import Breadcrumbs from "../components/astro/Breadcrumbs.astro";
import QuickAnswer from "../components/astro/QuickAnswer.astro";
import AffiliateDisclosure from "../components/astro/AffiliateDisclosure.astro";
import AuthorByline from "../components/astro/AuthorByline.astro";
import AffiliateIntercept from "../components/astro/AffiliateIntercept.astro";
import ComparisonTable from "../components/astro/ComparisonTable.astro";
import LessonPhraseList from "../components/astro/LessonPhraseList.astro";
import TrustBar from "../components/astro/TrustBar.astro";
import FAQSection from "../components/astro/FAQSection.astro";
import AffiliateCTA from "../components/astro/AffiliateCTA.astro";
import RelatedLinks from "../components/astro/RelatedLinks.astro";
import Quiz from "../components/react/Quiz.jsx";
import Section from "../components/astro/Section.astro";
import { lastUpdatedLabel } from "../lib/data.js";

const {
  lang,
  title,
  description,
  path,
  h1,
  crumbs,
  copy, // { quickAnswer, entity?, sections, tableTakeaway?, faq }
  intercept, // affiliate intercept text (from data)
  practicePhrases = [], // only when hasPronunciation === true
  relatedLinks = [],
  page = {},
  showQuiz = true,
  showTable = true,
} = Astro.props;

const updated = lastUpdatedLabel(page, lang);
const updatedLabel = lang === "es" ? "Actualizado" : "Last updated";
const sections = copy.sections || [];
const firstSections = sections.slice(0, 2);
const restSections = sections.slice(2);
const practiceHeading =
  lang === "es" ? "Practica estas frases en voz alta" : "Practice these phrases out loud";
const practiceSub =
  lang === "es"
    ? "Toca el altavoz para escuchar cada frase y repítela en voz alta. Hablar desde el primer día es lo que separa a quienes avanzan rápido de quienes se quedan estancados."
    : "Tap the speaker to hear each phrase, then say it out loud. Speaking from day one is what separates fast learners from stuck ones.";
const quizHeading = lang === "es" ? "¿No sabes por dónde empezar?" : "Not sure where to start?";
const quizSub =
  lang === "es"
    ? "Responde 2 preguntas y recibe una recomendación según tu forma de aprender."
    : "Answer 2 questions and get a recommendation matched to how you learn.";
const finalCtaLabel =
  lang === "es" ? "Prueba Rocket English Gratis →" : "Try Rocket English Free →";
---

<BaseLayout {lang} {title} {description} {path}>
  <main class="max-w-3xl mx-auto px-6 py-8">
    <Breadcrumbs {crumbs} />
    <p class="text-sm text-text-muted mb-2">{updatedLabel}: {updated}</p>
    <h1 class="font-display text-3xl sm:text-4xl font-bold text-navy-700 leading-tight mb-2">
      {h1}
    </h1>

    <QuickAnswer {lang} html={copy.quickAnswer} />
    <AffiliateDisclosure {lang} />
    <AuthorByline {lang} />

    <article class="mt-6">
      {copy.entity && <p class="text-lg text-navy-700 leading-relaxed mb-8">{copy.entity}</p>}

      {firstSections.map((section) => <Section {section} />)}

      {intercept && <AffiliateIntercept {lang} text={intercept} source="intercept" />}

      {showTable && <ComparisonTable {lang} takeaway={copy.tableTakeaway} />}

      {restSections.map((section) => <Section {section} />)}

      {
        practicePhrases.length > 0 && (
          <section class="my-10">
            <h2 class="font-sans text-2xl font-bold text-navy-700 mb-2">{practiceHeading}</h2>
            <p class="text-text-secondary mb-4">{practiceSub}</p>
            <LessonPhraseList phrases={practicePhrases} {lang} />
          </section>
        )
      }

      <TrustBar {lang} />

      {
        showQuiz && (
          <section class="my-10" id="quiz">
            <h2 class="font-sans text-2xl font-bold text-navy-700 mb-2">{quizHeading}</h2>
            <p class="text-text-secondary mb-4">{quizSub}</p>
            <Quiz client:visible {lang} compact={true} />
          </section>
        )
      }

      <FAQSection {lang} faq={copy.faq} />

      <AffiliateCTA
        {lang}
        source="cluster-footer"
        label={finalCtaLabel}
        sub={
          lang === "es"
            ? "Pago único, acceso de por vida, garantía de 60 días."
            : "One-time payment, lifetime access, 60-day guarantee."
        }
      />
    </article>

    <RelatedLinks {lang} links={relatedLinks} currentPath={path} />
  </main>
</BaseLayout>
