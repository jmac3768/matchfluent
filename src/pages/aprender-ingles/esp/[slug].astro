---
/**
 * The 7 ESP job lesson pages, generated from the esp-lesson entries in
 * keyword-clusters.json. Register follows conversion rules: usted for
 * professional/medical lessons, tú for the rest (handled in the
 * authored intros).
 */
import LessonLayout from "../../../layouts/LessonLayout.astro";
import LessonPhraseList from "../../../components/astro/LessonPhraseList.astro";
import { espLessons, internalLinks, makeTitle } from "../../../lib/data.js";
import { espIntros } from "../../../content/copy-es.js";

export function getStaticPaths() {
  return espLessons.map((lesson) => ({
    params: { slug: lesson.slug.replace("/aprender-ingles/esp/", "") },
    props: { lesson },
  }));
}

const { lesson } = Astro.props;
const intro = espIntros[lesson.id];

if (!intro) {
  throw new Error(`Missing authored intro for ESP lesson: ${lesson.slug}`);
}

const crumbs = [
  { name: "Inicio", path: "/" },
  { name: "Aprender Inglés", path: "/aprender-ingles" },
  { name: "Inglés por Profesión", path: "/aprender-ingles" },
  { name: lesson.h1, path: lesson.slug },
];

const title = makeTitle(lesson.h1, " | MatchFluent Lesson");
const phrasesHeading = "Las frases, con pronunciación";
---

<LessonLayout
  lang="es"
  {title}
  description={intro.description}
  path={lesson.slug}
  h1={lesson.h1}
  {crumbs}
  intro={intro.intro}
  closing={intro.closing}
  intercept={lesson.affiliateIntercept}
  relatedLinks={internalLinks.esp}
  page={lesson}
>
  <h2 class="font-sans text-2xl font-bold text-navy-700 mb-2">{phrasesHeading}</h2>
  <LessonPhraseList phrases={lesson.lessonPhrases} lang="es" />
</LessonLayout>
