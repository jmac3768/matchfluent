---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/astro/Breadcrumbs.astro";
import TrustBar from "../../components/astro/TrustBar.astro";
import { esMainPages, espLessons } from "../../lib/data.js";

const guides = esMainPages.filter((p) => p.type === "cluster");
const comparisons = esMainPages.filter((p) => p.type === "comparison");
const hubs = esMainPages.filter((p) => p.type === "glossary-hub");

const crumbs = [
  { name: "Inicio", path: "/" },
  { name: "Aprender Inglés", path: "/aprender-ingles" },
];

const groups = [
  { heading: "Guías completas", items: guides },
  { heading: "Comparaciones honestas", items: comparisons },
  { heading: "Métodos y conceptos", items: hubs },
  { heading: "Inglés por profesión (lecciones ESP)", items: espLessons },
];
---

<BaseLayout
  lang="es"
  title="Aprender Inglés: Guías y Recursos — MatchFluent"
  description="Todo lo que necesitas para aprender inglés — apps, cursos, podcasts, series y más. Guías en español."
  path="/aprender-ingles"
>
  <main class="max-w-container mx-auto px-6 py-10">
    <Breadcrumbs {crumbs} />
    <h1 class="font-display text-4xl font-bold text-navy-700 mb-3">
      Aprender Inglés: Guías, Herramientas y Recursos
    </h1>
    <p class="text-lg text-text-secondary max-w-2xl mb-2">
      Guías en español para hispanohablantes que quieren aprender inglés de verdad: qué apps sirven,
      qué métodos funcionan, y el inglés específico de tu trabajo — todo evaluado por lo que produce,
      no por lo que promete.
    </p>
    <p class="text-text-secondary max-w-2xl mb-6">
      ¿No sabes por dónde empezar? <a href="/#quiz" class="font-semibold text-teal-700 underline"
        >Haz el quiz de 2 minutos</a
      > y recibe una ruta según tu punto de partida.
    </p>
    <TrustBar lang="es" />

    {
      groups.map((group) => (
        <section class="my-10">
          <h2 class="font-sans text-2xl font-bold text-navy-700 mb-5">{group.heading}</h2>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {group.items.map((page) => (
              <a
                href={`${page.slug}/`}
                class="block rounded-xl border border-border bg-surface p-5 shadow-card hover:shadow-card-hover transition-shadow"
              >
                <h3 class="font-semibold text-navy-700 mb-1 leading-snug">{page.h1}</h3>
                <p class="text-xs font-mono text-text-muted">{page.primaryKeyword}</p>
              </a>
            ))}
          </div>
        </section>
      ))
    }
  </main>
</BaseLayout>
